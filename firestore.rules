rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny Catch-All
    match /{document=**} {
      allow read, write: if false;
    }

    // --- PHASE 3: Primitive Definitions ---
    function isSignedIn() { return request.auth != null; }
    function isEmailVerified() { return request.auth.token.email_verified == true; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    
    // Admin Check: Hardcoded jemalfano030@gmail.com or checked against a collection
    function isAdmin() { 
      return isSignedIn() && (
        request.auth.token.email == 'jemalfano030@gmail.com' || 
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    // --- PHASE 4: Entity Validation Blueprints ---

    function isValidUser(data) {
      return data.keys().hasAll(['id', 'name', 'email', 'role']) &&
             data.id is string && data.id.size() <= 128 &&
             data.name is string && data.name.size() <= 200 &&
             data.email is string && data.email.size() <= 200 &&
             data.role in ['student', 'teacher', 'admin'] &&
             (!data.has('points') || data.points is number) &&
             (!data.has('nid') || (data.nid is string && data.nid.size() <= 50));
    }

    function isValidCourse(data) {
      return data.keys().hasAll(['id', 'title', 'code']) &&
             data.id is string && data.id.size() <= 128 &&
             data.title is string && data.title.size() <= 200 &&
             data.code is string && data.code.size() <= 50;
    }

    function isValidExam(data) {
      return data.keys().hasAll(['id', 'title', 'courseCode']) &&
             data.id is string && data.id.size() <= 128 &&
             data.title is string && data.title.size() <= 200 &&
             data.courseCode is string && data.courseCode.size() <= 50;
    }

    function isValidNews(data) {
      return data.keys().hasAll(['id', 'title']) &&
             data.id is string && data.id.size() <= 128 &&
             data.title is string && data.title.size() <= 500;
    }

    function isValidExamResult(data) {
      return data.keys().hasAll(['examId', 'studentId', 'score']) &&
             data.examId is string && data.studentId is string &&
             data.score is number;
    }

    // --- COLLECTION MATCH BLOCKS ---

    match /users/{userId} {
      allow read: if isSignedIn() && (isOwner(userId) || isAdmin() || existing().role == 'teacher'); // Allow teachers to view student profiles if needed
      allow create: if isSignedIn() && isOwner(userId) && isValidUser(incoming());
      allow update: if isSignedIn() && (
        isAdmin() || 
        (isOwner(userId) && isValidUser(incoming()) && 
         incoming().diff(existing()).affectedKeys().hasOnly(['name', 'photo', 'preferredLanguage', 'completedLessons', 'completedExams', 'completedCourses', 'points']))
      );
      allow delete: if isAdmin();
    }

    match /courses/{courseId} {
      allow read: if true; // Public access to curriculum metadata
      allow write: if isAdmin();
    }

    match /exams/{examId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || (isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'teacher');
    }

    match /news/{newsId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /exam_results/{resultId} {
      allow get: if isSignedIn() && (isOwner(existing().studentId) || isAdmin());
      allow list: if isSignedIn() && (resource.data.studentId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && isOwner(incoming().studentId) && isValidExamResult(incoming());
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /admins/{adminId} {
      allow read: if isAdmin();
      allow write: if false; // Only manageable via console
    }
  }
}
